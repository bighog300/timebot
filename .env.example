# ── App ──────────────────────────────────────────────────────────────────────
DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
# Local defaults; set to your real frontend domains in shared/prod environments.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Database / migrations ────────────────────────────────────────────────────
DATABASE_URL=postgresql://docuser:docpass@localhost:5432/documents
# Keep false in normal setups. Only use true for isolated unit tests that skip Alembic.
ALEMBIC_SKIP=false

# ── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_MAX_RETRIES=3
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=UTC
CELERY_ENABLE_UTC=true
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000
CELERY_TASK_TIME_LIMIT=600
CELERY_TASK_SOFT_TIME_LIMIT=540
CELERY_TASK_DEFAULT_RETRY_DELAY=60

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
AI_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=4096

# ── Auth ─────────────────────────────────────────────────────────────────────
# REQUIRED outside local development. Generate with: python -c "import secrets;print(secrets.token_urlsafe(48))"
AUTH_SECRET_KEY=dev-insecure-change-me
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Storage ──────────────────────────────────────────────────────────────────
STORAGE_PATH=./data
UPLOAD_PATH=./data/uploads
PROCESSED_PATH=./data/processed

# ── Search / embeddings ──────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── Feature flags ────────────────────────────────────────────────────────────
ENABLE_AUTO_CATEGORIZATION=true
ENABLE_ENTITY_EXTRACTION=true
CATEGORY_CONFIDENCE_THRESHOLD=0.7
REVIEW_CONFIDENCE_THRESHOLD=0.75
MAX_UPLOAD_SIZE_MB=50

# ── Google OAuth connector foundation ────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5173/connections/callback?provider=gdrive
GOOGLE_OAUTH_SCOPES=openid,email,profile,https://www.googleapis.com/auth/drive.metadata.readonly
# REQUIRED when enabling connectors. Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONNECTOR_TOKEN_ENCRYPTION_KEY=
