# ── App ──────────────────────────────────────────────────────────────────────
DEBUG=false
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
# Local defaults; set to your real frontend domains in shared/prod environments.
ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174,http://192.168.88.212:5174

# ── Database / migrations ────────────────────────────────────────────────────
DATABASE_URL=postgresql://docuser:docpass@localhost:5432/documents
# Keep false in normal setups. Only use true for isolated unit tests that skip Alembic.
ALEMBIC_SKIP=false

# ── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_MAX_RETRIES=3
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=UTC
CELERY_ENABLE_UTC=true
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000
CELERY_TASK_TIME_LIMIT=600
CELERY_TASK_SOFT_TIME_LIMIT=540
CELERY_TASK_DEFAULT_RETRY_DELAY=60

# ── OpenAI ───────────────────────────────────────────────────────────────────
# Optional for boot/auth flows. Required only for AI enrichment and semantic embeddings.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
AI_MAX_TOKENS=4096

# ── Auth ─────────────────────────────────────────────────────────────────────
# LOCAL DEV: the default below works out of the box. App will log a warning.
# SHARED/PROD: generate a real secret with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Also set AUTH_SECRET_KEY in your shell / .env so docker compose picks it up:
#   export AUTH_SECRET_KEY=$(python -c "import secrets; print(secrets.token_urlsafe(48))")
AUTH_SECRET_KEY=
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=60
# Recommended production value: 15 (minutes)

# Optional first-run admin seed (idempotent):
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=
INITIAL_ADMIN_NAME=Timebot Admin
# Local/non-production only: force-reset password for INITIAL_ADMIN_EMAIL at startup
RESET_INITIAL_ADMIN_PASSWORD=false

# ── Storage ──────────────────────────────────────────────────────────────────
DATA_DIR=./data
UPLOAD_DIR=./data/uploads
ARTIFACT_DIR=./data/artifacts
# Legacy aliases (still supported)
STORAGE_PATH=./data
UPLOAD_PATH=./data/uploads
PROCESSED_PATH=./data/processed

# ── Search / embeddings ──────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── Feature flags ────────────────────────────────────────────────────────────
ENABLE_AUTO_CATEGORIZATION=true
ENABLE_ENTITY_EXTRACTION=true
CATEGORY_CONFIDENCE_THRESHOLD=0.7
REVIEW_CONFIDENCE_THRESHOLD=0.75
MAX_UPLOAD_SIZE_MB=50

# ── Google OAuth connector foundation (Google Drive connector only, not Timebot login) ─────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5174/connections/callback?provider=gdrive
GOOGLE_OAUTH_SCOPES=openid,email,profile,https://www.googleapis.com/auth/drive.metadata.readonly
# REQUIRED when enabling connectors. Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONNECTOR_TOKEN_ENCRYPTION_KEY=
